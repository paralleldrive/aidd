{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "paths": {
      "aidd/server": ["./src/server/index.js"],
      "aidd/utils": ["./utils/index.js"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  },
  "exclude": ["node_modules"],
  "include": [
    "lib/**/*.d.ts",
    "lib/**/*.test.js",
    "src/**/*.d.ts",
    "utils/**/*.d.ts",
    "utils/**/*.test.js"
  ]
}
